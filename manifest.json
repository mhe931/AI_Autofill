{
  "manifest_version": 3,
  "name": "AI Form Filler",
  "version": "1.0",
  "description": "Professional RPL and Credit Transfer automation tool for University of Vaasa students.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}